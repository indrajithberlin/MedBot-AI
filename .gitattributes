# Auto detect text files and normalize line endings
* text=auto

# Python
*.py text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Documentation
*.md text eol=lf

# Arduino
*.ino text eol=lf

# Environment files
*.env text eol=lf
*.example text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Fonts
*.ttf binary
*.otf binary